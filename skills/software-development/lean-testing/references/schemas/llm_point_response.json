{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM Vision Response — Point Recognition",
  "description": "Contract for LLM point recognition response (Vetka_dwg, MPT)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["number", "bbox", "confidence"],
    "properties": {
      "number": {
        "type": "integer",
        "minimum": 1,
        "description": "Point number visible on abriss"
      },
      "bbox": {
        "type": "array",
        "items": {"type": "number"},
        "minItems": 4,
        "maxItems": 4,
        "description": "[x, y, width, height] in image pixels"
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1,
        "description": "Model confidence score"
      }
    },
    "additionalProperties": false
  }
}