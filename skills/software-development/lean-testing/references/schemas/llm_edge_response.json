{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM Vision Response — Edge Recognition",
  "description": "Contract for LLM edge/connection recognition (Vetka_dwg)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["from_number", "to_number", "visual_kind", "confidence"],
    "properties": {
      "from_number": {
        "type": "integer",
        "minimum": 1
      },
      "to_number": {
        "type": "integer",
        "minimum": 1
      },
      "visual_kind": {
        "type": "string",
        "enum": ["solid", "dashed", "dotted", "double", "curve", "unknown"]
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    },
    "additionalProperties": false
  }
}